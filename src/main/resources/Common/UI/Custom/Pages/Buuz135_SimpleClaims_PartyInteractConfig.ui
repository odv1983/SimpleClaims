$C = "../Common.ui";

$C.@PageOverlay {

  $C.@DecoratedContainer {
    Anchor: (Width: 340, Height: 230);

    #Title {

      TextButton #BackButton {
        Anchor: (Left: 12, Top: 4, Width: 64, Height: 24);
        Padding: (Left: 8, Top: 2);
        Text: %ui.simpleclaims.party.back;
        Style: TextButtonStyle(
          Default: (LabelStyle: (FontSize: 14, TextColor: #93844c, RenderBold: true)),
          Sounds: $C.@ButtonSounds,
        );
        Background: #000000(0.13);
      }

      Group {
        $C.@Title #TitleText{
          @Text = %ui.simpleclaims.party.interactionSettings;
        }

      }
    }

    #Content {
      LayoutMode: Left;

      Group #Main {
        LayoutMode: Top;
        Padding: (Left: 40);
          $C.@CheckBoxWithLabel #InteractBlocksSetting {
            @Text = %ui.simpleclaims.party.allowBlockInteraction;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractChestSetting {
            @Text = %ui.simpleclaims.party.allowChestInteraction;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractDoorSetting {
            @Text = %ui.simpleclaims.party.allowDoorInteraction;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractBenchSetting {
            @Text = %ui.simpleclaims.party.allowBenchInteraction;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractChairSetting {
            @Text = %ui.simpleclaims.party.allowChairInteraction;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractPortalSetting {
            @Text = %ui.simpleclaims.party.allowPortalInteraction;
            Padding: (Bottom: 4);
          }
      }
    }
  }
}

$C.@BackButton {}