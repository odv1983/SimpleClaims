$C = "../Common.ui";

$C.@PageOverlay {

  $C.@DecoratedContainer {
    Anchor: (Width: 340, Height: 380);

    #Title {

      TextButton #BackButton {
        Anchor: (Left: 12, Top: 4, Width: 64, Height: 24);
        Padding: (Left: 8, Top: 2);
        Text: %ui.ui.simpleclaims.party.back;
        Style: TextButtonStyle(
          Default: (LabelStyle: (FontSize: 14, TextColor: #93844c, RenderBold: true)),
          Sounds: $C.@ButtonSounds,
        );
        Background: #000000(0.13);
      }

      Group {
        $C.@Title #TitleText{
          @Text = %ui.ui.simpleclaims.party.permissionSettings;
        }

      }
    }

    #Content {
      LayoutMode: Left;

      Group #Main {
        LayoutMode: Top;
        Padding: (Left: 40);
          $C.@CheckBoxWithLabel #PlaceBlocks {
            @Text = %ui.ui.simpleclaims.party.placeBlocks;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #BreakBlocks {
            @Text = %ui.ui.simpleclaims.party.breakBlocks;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractBlocks {
            @Text = %ui.ui.simpleclaims.party.interactBlocks;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractChest {
            @Text = %ui.ui.simpleclaims.party.interactChests;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractDoor {
            @Text = %ui.ui.simpleclaims.party.interactDoors;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractBench {
            @Text = %ui.ui.simpleclaims.party.interactBenches;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractChair {
            @Text = %ui.ui.simpleclaims.party.interactChairs;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InteractPortal {
            @Text = %ui.ui.simpleclaims.party.interactPortals;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #ModifyInfo {
            @Text = %ui.ui.simpleclaims.party.modifyPartyInfo;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #ClaimUnclaim {
            @Text = %ui.ui.simpleclaims.party.claimUnclaim;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #InvitePlayers {
            @Text = %ui.ui.simpleclaims.party.invitePlayers;
            Padding: (Bottom: 4);
          }
          $C.@CheckBoxWithLabel #AddAllies {
            @Text = %ui.ui.simpleclaims.party.addAllies;
            Padding: (Bottom: 4);
          }
      }
    }
  }
}

$C.@BackButton {}
