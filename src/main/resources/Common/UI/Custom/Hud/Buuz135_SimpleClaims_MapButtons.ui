$C = "../Common.ui";


Group  {
  Anchor: (Height: 38, Top: 0);
  Padding: (Top: 7);
  Background: (TexturePath: "../Common/ContainerHeaderNoRunes.png", HorizontalBorder: 35, VerticalBorder: 0);

  $C.@Title {
    @Text = "Simple Claims";
  }
}

Group{
  LayoutMode: Top;
  Anchor: (Top: 38, Height: 300);
  Background: (TexturePath: "../Common/ContainerPatch.png", Border: 23);
  Padding: 18;

  $C.@TextButton #EditPartyButton {
       Anchor: (Right: 10);
       Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
       Text: "Edit Party";
       Overscroll: false;
  }

  $C.@TextButton #EditPartyButton2 {
       Anchor: (Right: 10, Top: 8);
       Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
       Text: "Edit Party2";
       Overscroll: false;
  }
}
